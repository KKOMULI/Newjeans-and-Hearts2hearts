{
  "manifest_version": 3,
  "name": "mIrror",
  "version": "0.1.9",
  "description": "당신의 거래가 평소의 당신과 얼마나 다른지만 보여주는 거울. v0.1.7 UI를 유지하며 매수(경고) 클릭 결과 배너를 고정합니다.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.upbit.com/*",
    "https://upbit.com/*",
    "https://*.upbit.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://upbit.com/*",
        "https://*.upbit.com/*"
      ],
      "js": [
        "mirror-data.js",
        "mirror-core.js",
        "upbit-adapter.js",
        "upbit-risk.js",
        "content.js",
        "mirror-debug.js"
      ],
      "css": [
        "mirror.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "mIrror 설정",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "data/*.json"
      ],
      "matches": [
        "https://upbit.com/*",
        "https://*.upbit.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
